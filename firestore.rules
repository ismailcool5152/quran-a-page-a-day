rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidLesson(data) {
      return data.keys().hasAll(['mainIdea', 'rootWords', 'sideMargins', 'bottomMargins', 'dailyLife'])
          && data.keys().size() == 5
          && data.mainIdea is string
          && data.rootWords is string
          && data.sideMargins is string
          && data.bottomMargins is string
          && data.dailyLife is string;
    }

    match /lessons/{day} {
      allow read: if true;
      allow create: if isValidId(day) && isValidLesson(incoming());
      allow update: if isValidId(day) && isValidLesson(incoming());
    }

    match /metadata/{document} {
      allow read, write: if true;
    }
  }
}
