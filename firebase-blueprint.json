{
  "entities": {
    "Lesson": {
      "title": "Lesson",
      "description": "Cached lesson content for a specific day.",
      "type": "object",
      "properties": {
        "mainIdea": { "type": "string" },
        "rootWords": { "type": "string" },
        "sideMargins": { "type": "string" },
        "bottomMargins": { "type": "string" },
        "dailyLife": { "type": "string" }
      },
      "required": ["mainIdea", "rootWords", "sideMargins", "bottomMargins", "dailyLife"]
    }
  },
  "firestore": {
    "/lessons/{day}": {
      "schema": "Lesson",
      "description": "Stores the lessons generated by the LLM securely."
    },
    "/metadata/{document}": {
      "schema": "any",
      "description": "Stores metadata like sync state."
    }
  }
}
